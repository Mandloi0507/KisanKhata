# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./kisankhata.db

# === Security ===
SECRET_KEY=change-me-to-a-random-256-bit-string
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# === External APIs ===
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/climatology/point
AGMARKNET_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
AGMARKNET_API_KEY=your_data_gov_in_api_key_here

# === App ===
APP_ENV=development
LOG_LEVEL=INFO
INTERNAL_API_KEY=internal-dev-key-change-in-production

# === SMS (Optional — P1 Feature) ===
SMS_ENABLED=false
MSG91_AUTH_KEY=

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:8080,http://localhost:8081
